# Git Author Email
GIT_AUTHOR_EMAIL=you@example.com

# Space-separated list of repository paths to scan
# Example: /home/user/projects/repo1 /home/user/projects/repo2
GIT_REPO_PATHS=/path/to/repo1 /path/to/repo2

# Root directory to scan for git repositories (alternative to GIT_REPO_PATHS)
GIT_SCAN_ROOT=/path/to/projects

# Time window in days to look back for commits (default: 1)
GIT_TIME_WINDOW_DAYS=1

# Output format: terminal or markdown (default: terminal)
OUTPUT_FORMAT=terminal

# Output file path for markdown export (only used when OUTPUT_FORMAT=markdown)
OUTPUT_FILE=standup.md