# git-standup-wizard sample configuration
# Copy this file to .env in your project root and edit as needed.
# All variables are optional.

# Filter commits by author email (leave blank to show all authors)
# STANDUP_AUTHOR_EMAIL=jane.doe@example.com

# Filter commits by author name (leave blank to show all authors)
# STANDUP_AUTHOR_NAME=Jane Doe

# Comma-separated list of directories to scan for git repos
# STANDUP_REPO_PATHS=~/projects,~/work

# How many hours back to look for commits (default: 24)
# STANDUP_WINDOW_HOURS=24

# Maximum directory depth for repo discovery (default: 2)
# STANDUP_MAX_DEPTH=2

# Path to write a markdown report file (leave blank for terminal-only output)
# STANDUP_OUTPUT_PATH=./standup.md

# Set to true to include merge commits in the report (default: false)
# STANDUP_INCLUDE_MERGES=false
